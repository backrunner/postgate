{
  "name": "postgate",
  "version": "0.2.0-beta.3",
  "private": true,
  "description": "A Tauri 2.0 based MITM proxy tool for local frontend development",
  "scripts": {
    "dev": "turbo dev --filter=@postgate/shared --filter=@postgate/plugin-sdk --filter=@postgate/inject-client",
    "dev:desktop": "pnpm dev & pnpm --filter @postgate/desktop tauri:dev",
    "tauri:dev": "pnpm run build:packages && pnpm --filter @postgate/desktop tauri:dev",
    "tauri:build": "pnpm run build:packages && pnpm --filter @postgate/desktop tauri:build",
    "build": "turbo build",
    "build:packages": "turbo build --filter=@postgate/shared --filter=@postgate/plugin-sdk --filter=@postgate/inject-client",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules",
    "typecheck": "turbo typecheck",
    "package:setup": "bash scripts/package-setup.sh",
    "package:mac": "bash scripts/package.sh mac",
    "package:mac:universal": "bash scripts/package.sh mac-universal",
    "package:mac:intel": "bash scripts/package.sh mac-intel",
    "package:win": "bash scripts/package.sh win",
    "package:all": "bash scripts/package.sh all"
  },
  "devDependencies": {
    "turbo": "^2.10.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": ">=22.13.0"
  }
}
