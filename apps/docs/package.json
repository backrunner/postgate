{
  "name": "@postgate/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "svedocs dev",
    "build": "svedocs og && svedocs build --mode static --no-og",
    "preview": "svedocs preview",
    "check": "svedocs check && svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "svedocs check",
    "cloudflare:whoami": "wrangler whoami",
    "cloudflare:create": "wrangler pages project create postgate-docs --production-branch main",
    "deploy": "pnpm check && pnpm build && wrangler pages deploy build --project-name postgate-docs --branch main",
    "deploy:preview": "pnpm check && pnpm build && wrangler pages deploy build --project-name postgate-docs --branch preview"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.60.1",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tailwindcss/vite": "4.3.0",
    "lucide-svelte": "1.0.1",
    "svelte": "5.55.7",
    "svedocs": "0.1.0-beta.7",
    "tailwindcss": "4.3.0",
    "vite": "8.0.13"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "svelte-check": "4.7.2",
    "svedocs-cli": "0.1.0-beta.7",
    "typescript": "6.0.3",
    "wrangler": "4.110.0"
  }
}
